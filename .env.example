# Configuración de base de datos (se usa localhost para desarrollo local)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/monitoring_db

# Llave secreta para generación de tokens JWT
SECRET_KEY=change_me_to_a_secure_random_key_123456789

# Ruta al archivo de credenciales de Firebase Cloud Messaging
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json

# Parámetros de Alerta
ALERT_OUTSIDE_CONSECUTIVE_LIMIT=3
ALERT_OUTSIDE_SECONDS_LIMIT=15
ALERT_COOLDOWN_SECONDS=300
GPS_TOLERANCE_METERS=15
